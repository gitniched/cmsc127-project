{
  "compilerOptions": {
    "target": "ES2022",
    "esModuleInterop": true,
    "declaration": true,
    "rootDir": ".",
    "outDir": "./dist",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
  },
  "include": [
    "types/**/*",
    "*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}